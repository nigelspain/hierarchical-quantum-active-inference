import argparse
from qiskit.qasm3 import loads
from qiskit_aer import AerSimulator
from qiskit import transpile
from qiskit.visualization import plot_histogram
import matplotlib.pyplot as plt

def emulate_circuit():
    # 1. Set up argument parsing to handle your flags
    parser = argparse.ArgumentParser(description="Emulate a braided topological circuit.")
    parser.add_argument("--config", type=str, default="braided_topological_engine.qasm", help="Path to QASM file")
    parser.add_argument("--output", type=str, help="Path to save the output plot image")
    parser.add_argument("--phase", type=int, help="Phase parameter (currently unused by simulation logic)")
    parser.add_argument("--plot", action="store_true", help="Generate and save/show a plot of the results")
    
    args = parser.parse_args()

    # 2. Load the specified QASM file
    with open(args.config, "r") as f:
        qasm_str = f.read()
    
    circuit = loads(qasm_str)
    
    # 3. Run the simulation
    simulator = AerSimulator()
    compiled_circuit = transpile(circuit, simulator)
    
    result = simulator.run(compiled_circuit, shots=1024).result()
    counts = result.get_counts()
    
    print("--- Emulation Results ---")
    print(counts)

    # 4. Handle plotting and saving if requested
    if args.plot or args.output:
        # Generate Qiskit's standard histogram plot
        plot_histogram(counts)
        
        if args.output:
            # Save the figure to the path specified in --output
            plt.savefig(args.output, bbox_inches='tight')
            print(f"Plot successfully saved to {args.output}")
        else:
            # Fallback if --plot is passed without an explicit filename
            plt.savefig("emulation_result.png", bbox_inches='tight')
            print("Plot successfully saved to emulation_result.png")

if __name__ == "__main__":
    emulate_circuit()
